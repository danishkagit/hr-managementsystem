# ─────────────────────────────────────────────────
# HR Management System - Environment Variables
# ─────────────────────────────────────────────────
# Copy this file to .env and adjust values for your environment.
# For Railway deployment, set these in the Railway dashboard instead.

# Server
NODE_ENV=development
PORT=4000
HOST=0.0.0.0

# ────────────────────────────
# Database (PostgreSQL)
# Railway users: DATABASE_URL is auto-injected by the Postgres plugin.
# You can also set individual params below instead.
# ────────────────────────────
# DATABASE_URL=postgresql://user:password@host:5432/hr_management?sslmode=require
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=hr_management
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_DIALECT=postgres
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_POOL_ACQUIRE=30000
DB_POOL_IDLE=10000

# JWT
JWT_SECRET=change-this-to-a-strong-random-string
JWT_EXPIRES_IN=8h
JWT_REFRESH_EXPIRES_IN=7d

# CORS - comma-separated origins (update with your Railway domain!)
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# WebSocket
WS_PATH=/socket.io

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Logging
LOG_LEVEL=info
LOG_FILE_PATH=logs/app.log
